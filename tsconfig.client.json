{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM"],
    "noEmit": true,
    "noEmitOnError": true
  },
  "include": ["client/**/*.ts"],
  "exclude": ["node_modules", "server.ts"]
}
