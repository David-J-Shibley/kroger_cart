{
  "name": "kroger-cart",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsx server.ts",
    "serve": "tsx server.ts",
    "build": "npm run build:client && node scripts/prepare-capacitor-www.mjs",
    "build:client": "tsc -p tsconfig.client.json && mkdir -p dist && rm -f dist/*.js && esbuild client/kroger-cart.ts --bundle --outfile=dist/kroger-cart.js --format=esm --target=es2020",
    "cap:prepare": "node scripts/prepare-capacitor-www.mjs",
    "cap:sync": "npm run build:client && npm run cap:prepare && npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1018.0",
    "@aws-sdk/lib-dynamodb": "^3.1018.0",
    "aws-jwt-verify": "^5.1.1",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "oidc-client-ts": "^3.5.0",
    "pino": "^10.3.1",
    "react-oidc-context": "^3.3.1",
    "stripe": "^21.0.1"
  }
}
